# =====================================================================
# GLS Library — Backend Environment Variables
# Loaded by `dotenv` (already in package.json).
# Do NOT commit this file — it is listed in gitignore.txt.
# =====================================================================

# ---- Server ---------------------------------------------------------
# Used by Controller/Admin/SendOTP.js (`process.env.PORT || 3000`).
# index.js currently hardcodes 3000, so the live listen port is 3000.
PORT=3000

# ---- JWT ------------------------------------------------------------
# Signing/verifying secret. Used in:
#   Middleware/authenticate_me.js
#   Controller/authController.js
#   Model/Admin.js, Model/Faculty.js, Model/Student.js
#   config/GenerateAccessToken.js
JWT_SECRET_KEY=gls_mca

# Header name read by config/VerifyAccessToken.js. Currently dead code,
# kept for completeness / future use.
TOKEN_HEADER_KEY=auth-token

